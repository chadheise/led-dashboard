{
  "permissions": {
    "allow": [
      "Bash(.venv/bin/python -m pytest *)",
      "Bash(cd *)",
      "Bash(git *)",
      "Bash(gh api *)",
      "Bash(gh repo *)",
      "Bash(.venv/bin/python -c ' *)",
      "Skill(update-config)",
      "Skill(update-config:*)",
      "Bash(PYTHONPATH=. .venv/bin/python -m tests.framework.contact_sheet --app sports --fixture fifa_wc_group_in_progress --scale 4)",
      "Bash(PYTHONPATH=. .venv/bin/python -m tests.framework.contact_sheet --app sports --scale 4 --heights 64)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
