[Unit]
Description=LED Dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/led-dashboard
ExecStart=/home/pi/led-dashboard/start.sh
Restart=on-failure
RestartSec=15
StandardOutput=journal
StandardError=journal
SyslogIdentifier=led-dashboard

[Install]
WantedBy=multi-user.target
