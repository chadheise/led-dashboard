# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/

# Node
ui/node_modules/
ui/dist/
ui/.vite/

# Editor
.DS_Store
.vscode/
*.swp

# Claude Code -- ignore local/personal state, but commit the shared
# agent context: SessionStart hook + the settings that register it.
# (Ignore directory *contents* so specific paths can be re-included; a
# directory-level ignore would block the negations below.)
.claude/*
!.claude/settings.json
!.claude/hooks/

# Persisted runtime state (user data, not code)
engine/data/

# Test artifacts (diff images, contact sheets) — goldens in tests/snapshots/ ARE committed
engine/tests/output/
